# Backend env vars
# Copy to `.env` and fill in real values.
OPENAI_API_KEY=sk-your-openai-key
# Optional: point to any OpenAI-compatible endpoint (Cerebras, Ollama, vLLM, LM Studio, etc.)
# Leave empty/unset to use the official OpenAI API.
# Cerebras:  AI_PROVIDER_URL=https://api.cerebras.ai/v1
# Ollama:   AI_PROVIDER_URL=http://localhost:11434/v1
OPENAI_MODEL=gpt-4o-mini
# Max size per uploaded file, in MB.
MAX_UPLOAD_MB=10
NEXTAUTH_SECRET=replace-with-a-random-string
ALLOWED_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=10
DATABASE_URL=postgresql://projectai:S3cretPrj@127.0.0.1/pinterest_analyzer